      <div style={{background:"#0B0B12",borderBottom:"1px solid #18182B",padding:"10px 16px",position:"sticky",top:0,zIndex:100}}>
        <div style={{maxWidth:1400,margin:"0 auto",display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:8}}>
          <div style={{display:"flex",alignItems:"center",gap:8}}>
            <button onClick={function(){setView(null);stopRef.current=true;setRunning(false);}} style={{background:"transparent",border:"1px solid #18182B",borderRadius:4,padding:"4px 8px",fontSize:10,color:"#71717A",cursor:"pointer"}}>← Back</button>
            <span style={{fontSize:16}}>{sec?sec.icon:""}</span>
            <div>
              <div style={{fontSize:14,fontWeight:700,color:"#FAFAFA"}}>{sec?sec.name:""}</div>
              <div style={{fontSize:8,color:"#525280",fontFamily:mono}}>{sec?sec.topics.length:0} topics · {PARALLEL}x parallel</div>
            </div>
          </div>
          <div style={{display:"flex",alignItems:"center",gap:6,flexWrap:"wrap"}}>
            <input value={tkFilter} onChange={function(e){setTkFilter(e.target.value);}} placeholder="Ticker..." style={{background:"#111118",border:"1px solid #18182B",borderRadius:4,padding:"4px 8px",fontSize:10,color:"#E5E5E5",fontFamily:mono,width:80,outline:"none"}}/>
            <button onClick={function(){setLogVis(!logVis);}} style={{background:logVis?"#18182B":"transparent",border:"1px solid #18182B",borderRadius:4,padding:"4px 7px",fontSize:8,color:"#525280",cursor:"pointer"}}>LOG</button>
            {running&&<span style={{fontSize:9,color:"#818CF8",fontFamily:mono}}>{prog.done}/{prog.total}</span>}
            {running&&elapsed>0&&<span style={{fontSize:9,color:"#525280",fontFamily:mono}}>{elapsed}s</span>}
            {running&&<button onClick={function(){stopRef.current=true;log("⏹");setRunning(false);}} style={{background:"#1C1017",color:"#F87171",border:"1px solid #7F1D1D44",padding:"4px 10px",fontSize:10,fontWeight:600,borderRadius:4,cursor:"pointer"}}>■</button>}
            <button onClick={scanSector} disabled={running} style={{background:running?"#18182B":"linear-gradient(135deg,"+((sec?sec.color:"#6366F1")+",#8B5CF6)"),color:running?"#525280":"#FFF",border:"none",padding:"5px 14px",fontSize:10,fontWeight:600,borderRadius:4,cursor:running?"not-allowed":"pointer"}}>
              {running?"⏳ Scanning...":"▶ SCAN ALL TOPICS"}
            </button>
          </div>
        </div>
        {running&&<div style={{maxWidth:1400,margin:"6px auto 0",height:3,background:"#18182B",borderRadius:2,overflow:"hidden"}}><div style={{height:"100%",width:(prog.done/(prog.total||1)*100)+"%",background:"linear-gradient(90deg,"+(sec?sec.color:"#6366F1")+",#EC4899)",transition:"width 0.3s"}}/></div>}
      </div>

      <div style={{maxWidth:1400,margin:"0 auto",padding:"12px 16px"}}>

        {logVis&&<div style={{background:"#0A0A12",border:"1px solid #18182B",borderRadius:6,padding:"6px 10px",marginBottom:10,maxHeight:120,overflowY:"auto",fontSize:9,fontFamily:mono,color:"#71717A",lineHeight:1.7}}>{logs.length===0?"Waiting...":logs.map(function(l,i){return <div key={i}>{l}</div>;})}</div>}

        {/* Topic chips */}
        {sec&&<div style={{display:"flex",gap:4,flexWrap:"wrap",marginBottom:12}}>
          {sec.topics.map(function(t){
            return <button key={t.id} onClick={function(){if(!running)scanOne(t);}}
              style={{background:results[t.id]?"#12121C":"#0A0A10",border:"1px solid "+(results[t.id]?(sec.color+"33"):"#18182B"),color:results[t.id]?sec.color:"#52525B",padding:"3px 8px",borderRadius:4,fontSize:9,cursor:running?"not-allowed":"pointer"}}>
              {results[t.id]?"✓":"○"} {t.label}
            </button>;
          })}
        </div>}

        {nI>0&&<div style={{display:"flex",gap:10,padding:"7px 12px",background:"#0A0A12",border:"1px solid #18182B",borderRadius:5,marginBottom:10,flexWrap:"wrap",fontSize:10,fontFamily:mono}}>
          <span style={{color:"#4ADE80",fontWeight:600}}>▲{nB}</span>
          <span style={{color:"#F87171",fontWeight:600}}>▼{nR}</span>
          <span style={{color:"#A8A29E",fontWeight:600}}>—{nN}</span>
          <span style={{color:"#525280"}}>{nI} items · {Object.keys(tkS).length} tickers</span>
          {!running&&elapsed>0&&<span style={{color:sec?sec.color:"#818CF8",marginLeft:"auto"}}>⚡ {elapsed}s</span>}
        </div>}

        {errs.length>0&&<div style={{background:"#1C0A0A",border:"1px solid #7F1D1D33",borderRadius:5,padding:"6px 10px",marginBottom:8,fontSize:9,color:"#FCA5A5",fontFamily:mono}}>Issues: {errs.filter(function(v,i,a){return a.indexOf(v)===i;}).join(", ")}</div>}

        {order.length===0&&!running&&<div style={{textAlign:"center",padding:"50px 20px"}}>
          <div style={{fontSize:36,opacity:0.4}}>{sec?sec.icon:"📊"}</div>
          <div style={{fontSize:13,fontWeight:600,color:"#52525B",marginTop:8}}>{sec?sec.name:""}</div>
          <div style={{fontSize:10,color:"#3F3F50",fontFamily:mono,marginTop:6}}>Hit "SCAN ALL TOPICS" or click individual topics above</div>
        </div>}

        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(420px,1fr))",gap:10}}>
          {vis.map(function(tid){
            var top=null;if(sec)for(var j=0;j<sec.topics.length;j++)if(sec.topics[j].id===tid)top=sec.topics[j];
            var dat=results[tid];if(!top||!dat)return null;
            var isOpen=opened[tid]!==false;var items=dat.items||[];
            return(
              <div key={tid} style={{background:"#0C0C14",border:"1px solid #18182B",borderRadius:7,overflow:"hidden"}}>
                <div onClick={function(){setOpened(function(p){var n=Object.assign({},p);n[tid]=!isOpen;return n;});}}
                  style={{padding:"8px 12px",borderBottom:isOpen?"1px solid #18182B":"none",display:"flex",alignItems:"center",gap:5,cursor:"pointer"}}>
                  <span style={{fontSize:10.5,fontWeight:600,color:sec?sec.color:"#818CF8"}}>{top.label}</span>
                  {top.tickers&&<span style={{fontSize:7,color:"#3F3F50",fontFamily:mono}}>{top.tickers}</span>}
                  <span style={{flex:1}}/>
                  <span style={{fontSize:8,color:"#3F3F50",fontFamily:mono}}>{items.length} {isOpen?"▾":"▸"}</span>
                </div>
                {isOpen&&<div>
                  {dat.headline&&<div style={{padding:"6px 12px 2px",fontSize:11,fontWeight:500,color:"#D4D4D8"}}>{dat.headline}</div>}
                  <div style={{padding:"4px 12px 8px"}}>
                    {items.map(function(item,idx){
                      var vote=getVote(tid,item.title);
                      var sC=item.sentiment==="bullish"?"#4ADE80":item.sentiment==="bearish"?"#F87171":"#A8A29E";
                      var sB=item.sentiment==="bullish"?"#052E16":item.sentiment==="bearish"?"#450A0A":"#1C1917";
                      var sL=item.sentiment==="bullish"?"▲":item.sentiment==="bearish"?"▼":"—";
                      var rC=item.relevance==="high"?"#EF4444":item.relevance==="medium"?"#F59E0B":"#525280";
                      return(
                        <div key={idx} style={{padding:"6px 0",borderBottom:idx<items.length-1?"1px solid #0F0F1C":"none"}}>
                          <div style={{display:"flex",alignItems:"center",gap:4,flexWrap:"wrap"}}>
                            <span style={{width:6,height:6,borderRadius:"50%",background:rC,display:"inline-block"}}/>
                            <span style={{fontSize:10.5,fontWeight:600,color:"#E4E4E7",flex:1,minWidth:50}}>{item.title}</span>
                            <span style={{background:sB,color:sC,padding:"1px 6px",borderRadius:3,fontSize:9,fontWeight:700,fontFamily:mono}}>{sL}</span>
                          </div>
                          <p style={{fontSize:10,color:"#A1A1AA",margin:"2px 0 0 10px",lineHeight:1.45}}>{item.summary}</p>
                          <div style={{display:"flex",alignItems:"center",gap:3,marginLeft:10,marginTop:3,flexWrap:"wrap"}}>
                            {(item.tickers||[]).map(function(t,j){return <span key={j} style={{background:"#14142B",color:"#818CF8",padding:"1px 4px",borderRadius:2,fontSize:7,fontWeight:600,fontFamily:mono}}>${t}</span>;})}
                            <button onClick={function(ev){ev.stopPropagation();doVote(tid,item.title,"up");}}
                              style={{background:vote==="up"?"#052E16":"transparent",border:"1px solid "+(vote==="up"?"#4ADE8044":"#18182B"),borderRadius:3,padding:"1px 5px",fontSize:10,cursor:"pointer",color:vote==="up"?"#4ADE80":"#525280",marginLeft:4,lineHeight:1}}>👍</button>
                            <button onClick={function(ev){ev.stopPropagation();doVote(tid,item.title,"down");}}
                              style={{background:vote==="down"?"#450A0A":"transparent",border:"1px solid "+(vote==="down"?"#F8717144":"#18182B"),borderRadius:3,padding:"1px 5px",fontSize:10,cursor:"pointer",color:vote==="down"?"#F87171":"#525280",lineHeight:1}}>👎</button>
                            <span style={{flex:1}}/>
                            {item.source&&<span style={{fontSize:7,color:"#3F3F50",fontFamily:mono}}>{item.source}</span>}
                            {item.url&&item.url.indexOf("http")===0&&(
                              <a href={item.url} target="_blank" rel="noopener noreferrer"
                                style={{fontSize:7,fontWeight:700,fontFamily:mono,color:sec?sec.color:"#818CF8",textDecoration:"none",background:(sec?sec.color:"#818CF8")+"14",border:"1px solid "+(sec?sec.color:"#818CF8")+"30",padding:"1px 6px",borderRadius:3}}>↗ SRC</a>
                            )}
                          </div>
                        </div>
                      );
                    })}
                  </div>
                  {dat.signal&&<div style={{padding:"5px 12px 8px",borderTop:"1px solid #0F0F1C",fontSize:9,color:"#71717A",fontFamily:mono}}><span style={{color:sec?sec.color:"#818CF8",fontWeight:700}}>SIGNAL:</span> {dat.signal}</div>}
                </div>}
              </div>
            );
          })}
        </div>
      </div>
    </div>
  );
}
