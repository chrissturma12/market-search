var API="https://api.anthropic.com/v1/messages";
var PARALLEL=3;
var GAP=1500;

function sleep(ms){return new Promise(function(r){setTimeout(r,ms);});}

function tryJSON(t){
  if(!t)return null;
  var c=t.replace(/```json/gi,"").replace(/```/gi,"").trim();
  try{return JSON.parse(c);}catch(e){}
  var s=c.indexOf("{");if(s<0)return null;
  var d=0;
  for(var i=s;i<c.length;i++){if(c[i]==="{")d++;if(c[i]==="}")d--;if(d===0){try{return JSON.parse(c.substring(s,i+1));}catch(e2){return null;}}}
  return null;
}
function getURLs(c){try{var s=JSON.stringify(c);var m=s.match(/https?:\/\/[^\s"'<>\\)}\]]+/g)||[];var o=[],seen={};for(var i=0;i<m.length;i++)if(m[i].length<250&&!seen[m[i]]&&m[i].indexOf("anthropic")<0&&m[i].indexOf("googleapis")<0){seen[m[i]]=true;o.push(m[i]);}return o;}catch(e){return[];}}
function getTexts(c){var o="";if(!c)return o;for(var i=0;i<c.length;i++)if(c[i].type==="text"&&c[i].text)o+=c[i].text+"\n";return o;}

async function doScan(topic){
  var yr=new Date().getFullYear();
  var q=topic.query+" "+yr;
  for(var a=0;a<2;a++){
    if(a>0)await sleep(6000);
    try{
      var r=await fetch(API,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({
        model:"claude-sonnet-4-20250514",max_tokens:900,
        tools:[{type:"web_search_20250305",name:"web_search"}],
        messages:[{role:"user",content:"Search web: "+q+"\nTickers: "+(topic.tickers||"sector")+
          '\nReturn ONLY JSON:\n{"headline":"takeaway","items":[{"title":"title","summary":"2-3 sentences","sentiment":"bullish/bearish/neutral","relevance":"high/medium/low","tickers":["X"],"source":"name","url":"https://url"}],"signal":"signal"}\n3-5 items. Real URLs. JSON only.'}]
      })});
      if(r.status===429||r.status===529){if(a<1)continue;return{ok:false,err:"Rate limited"};}
      if(!r.ok)return{ok:false,err:"HTTP "+r.status};
      var json=await r.json();var text=getTexts(json.content);var urls=getURLs(json.content);var parsed=tryJSON(text);
      if(parsed&&parsed.items&&parsed.items.length>0){
        for(var k=0;k<parsed.items.length;k++){var it=parsed.items[k];if(!it.url||it.url.indexOf("http")!==0)it.url=urls[k]||urls[0]||"";if(!it.tickers)it.tickers=[];if(!it.sentiment)it.sentiment="neutral";if(!it.relevance)it.relevance="medium";}
        return{ok:true,data:parsed};
      }
      if(text.length>30&&a<1)continue;
      if(text.length>30){var tks=topic.tickers?topic.tickers.split(",").map(function(x){return x.trim();}).slice(0,3):[];return{ok:true,data:{headline:topic.label,signal:"Raw",items:[{title:topic.label,summary:text.replace(/[{}"[\]]/g," ").replace(/\s+/g," ").trim().slice(0,350),sentiment:"neutral",relevance:"medium",tickers:tks,source:"Web",url:urls[0]||""}]}};}
      if(a<1)continue;return{ok:false,err:"Empty"};
    }catch(err){if(a<1)continue;return{ok:false,err:err.message};}
  }
  return{ok:false,err:"Failed"};
}

async function runBatch(topics,onResult,onLog,stopRef){
  var i=0;
  while(i<topics.length){
    if(stopRef.current)break;
    var batch=topics.slice(i,i+PARALLEL);
    onLog("⚡ "+batch.map(function(t){return t.label;}).join(", "));
    await Promise.all(batch.map(function(t){return doScan(t).then(function(r){onResult(t,r);});}));
    i+=PARALLEL;
    if(i<topics.length&&!stopRef.current)await sleep(GAP);
  }
}

